<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Predator"
        x:Class="Predator.ColumnDesignWindow"
        x:DataType="local:ColumnDesignWindow"
        Title="Diseño de Columnas"
        Width="400"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <DockPanel Margin="10">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top" 
                   Text="Seleccione las columnas a mostrar y ordene su posición:"
                   Margin="0,0,0,10"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,10,0,0">
            <Button Content="Aceptar" Click="OnOkClick" Width="80" />
            <Button Content="Cancelar" Click="OnCancelClick" Width="80" />
        </StackPanel>

        <!-- Columns list -->
        <ListBox x:Name="ColumnsList" 
                 SelectionMode="Single"
                 Margin="0,0,0,10">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="MinHeight" Value="24" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:ColumnConfig">
                    <Border Padding="4,2" BorderThickness="0,0,0,1" BorderBrush="LightGray">
                        <Grid ColumnDefinitions="30,*,30,30">
                            <!-- Checkbox -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsVisible}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center" />
                            
                            <!-- Column name -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Header}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       FontSize="11" />
                            
                            <!-- Up button -->
                            <Button Grid.Column="2"
                                    Content="▲"
                                    Padding="5"
                                    FontSize="10"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Click="OnMoveUpClick"
                                    Tag="{Binding DisplayOrder}" />
                            
                            <!-- Down button -->
                            <Button Grid.Column="3"
                                    Content="▼"
                                    Padding="5"
                                    FontSize="10"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Click="OnMoveDownClick"
                                    Tag="{Binding DisplayOrder}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
